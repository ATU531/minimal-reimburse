<view class="page">
  <view class="hero-card">
    <view class="hero-title">{{currentView.title}}</view>
    <view class="hero-desc">{{currentView.subtitle}}</view>
  </view>

  <view class="section-card">
    <view class="section-title">导出任务</view>
    <view class="task-list">
      <view class="task-item" wx:for="{{exportTasks}}" wx:key="title" wx:for-item="item">
        <view>
          <view class="task-title">{{item.title}}</view>
          <view class="task-desc">{{item.desc}}</view>
        </view>
        <view class="task-status">{{item.status}}</view>
      </view>
    </view>
  </view>

  <view class="section-card">
    <view class="section-title">导出预设</view>
    <view class="preset-list">
      <view class="preset-item" wx:for="{{presets}}" wx:key="*this" wx:for-item="item">{{item}}</view>
    </view>
  </view>

  <view class="bottom-actions">
    <view class="secondary-btn" data-label="预览导出内容" bindtap="handleTap">预览内容</view>
    <view class="primary-btn" data-label="生成导出文件" bindtap="handleTap">生成文件</view>
  </view>
</view>
