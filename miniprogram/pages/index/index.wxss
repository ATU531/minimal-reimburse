page {
  background: #f4f7fb;
}

.container {
  padding: 32rpx 24rpx 44rpx;
  font-family: PingFang SC;
  color: #182230;
}

.hero-card {
  padding: 36rpx;
  border-radius: 36rpx;
  background: linear-gradient(135deg, #eef4ff 0%, #dfe8ff 50%, #ebe4ff 100%);
  box-shadow: 0 20rpx 50rpx rgba(79, 110, 247, 0.12);
}

.hero-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 24rpx;
}

.hero-kicker {
  font-size: 24rpx;
  color: #4f6ef7;
  letter-spacing: 2rpx;
}

.hero-title {
  margin-top: 16rpx;
  font-size: 44rpx;
  font-weight: 600;
  line-height: 1.3;
}

.hero-desc {
  margin-top: 16rpx;
  font-size: 26rpx;
  line-height: 1.7;
  color: #475467;
}

.hero-badge {
  padding: 12rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.72);
  color: #4f6ef7;
  font-size: 22rpx;
}

.hero-stats {
  display: flex;
  gap: 16rpx;
  margin-top: 30rpx;
}

.hero-stat {
  flex: 1;
  padding: 22rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.76);
}

.hero-stat-value {
  font-size: 36rpx;
  font-weight: 600;
  color: #101828;
}

.hero-stat-label {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #667085;
}

.section {
  margin-top: 28rpx;
}

.section-header {
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #101828;
}

.section-desc {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #667085;
}

.entry-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.entry-card {
  width: calc(50% - 8rpx);
  padding: 20rpx 22rpx;
  box-sizing: border-box;
  background: #ffffff;
  border-radius: 20rpx;
  box-shadow: 0 6rpx 20rpx rgba(16, 24, 40, 0.04);
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.entry-icon {
  width: 56rpx;
  height: 56rpx;
  min-width: 56rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #4f6ef7 0%, #89a4ff 100%);
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}

.entry-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #101828;
}

.entry-desc {
  display: none;
}

.feature-list,
.reminder-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.feature-card,
.reminder-card {
  background: #ffffff;
  border-radius: 28rpx;
  padding: 28rpx;
  box-shadow: 0 10rpx 30rpx rgba(16, 24, 40, 0.05);
}

.feature-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.feature-main {
  flex: 1;
}

.feature-title-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.feature-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #101828;
}

.feature-tag {
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: #eef2ff;
  color: #4f46e5;
  font-size: 20rpx;
}

.feature-desc {
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #667085;
}

.feature-arrow {
  color: #98a2b3;
  font-size: 30rpx;
}

.reminder-label {
  font-size: 24rpx;
  color: #667085;
}

.reminder-value {
  margin-top: 14rpx;
  font-size: 48rpx;
  font-weight: 600;
  color: #101828;
}

.reminder-helper {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #667085;
}

.floating-note {
  margin-top: 28rpx;
  padding: 28rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.72);
  border: 1rpx solid rgba(79, 110, 247, 0.12);
}

.floating-note-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #344054;
}

.floating-note-text {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #667085;
}

.page-spacer {
  height: 40rpx;
}
