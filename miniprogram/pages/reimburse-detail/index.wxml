<view class="page">
  <view class="hero-card">
    <view class="hero-row">
      <view>
        <view class="hero-title">{{currentView.title}}</view>
        <view class="hero-desc">{{currentView.subtitle}}</view>
      </view>
      <view class="hero-status">{{currentView.status}}</view>
    </view>
    <view class="hero-amount">{{currentView.amount}}</view>
  </view>

  <view class="section-card">
    <view class="section-head">
      <view class="section-title">基础信息</view>
      <view class="section-link" bindtap="toggleEditMode">{{editMode ? '取消编辑' : '编辑信息'}}</view>
    </view>
    <view class="info-list" wx:if="{{!editMode}}">
      <view class="info-row" wx:for="{{sections}}" wx:key="label" wx:for-item="item">
        <view class="info-label">{{item.label}}</view>
        <view class="info-value">{{item.value}}</view>
      </view>
    </view>
    <view class="edit-form" wx:if="{{editMode}}">
      <view class="edit-field">
        <view class="edit-label">报销单标题</view>
        <input class="edit-input" value="{{editForm.title}}" data-field="title" bindinput="handleEditInput" />
      </view>
      <view class="edit-field">
        <view class="edit-label">报销人</view>
        <input class="edit-input" value="{{editForm.applicant}}" data-field="applicant" bindinput="handleEditInput" />
      </view>
      <view class="edit-field">
        <view class="edit-label">报销部门</view>
        <input class="edit-input" value="{{editForm.department}}" data-field="department" bindinput="handleEditInput" />
      </view>
      <view class="edit-field">
        <view class="edit-label">关联项目</view>
        <input class="edit-input" value="{{editForm.projectName}}" data-field="projectName" bindinput="handleEditInput" />
      </view>
      <view class="edit-field">
        <view class="edit-label">费用分类</view>
        <input class="edit-input" value="{{editForm.expenseCategory}}" data-field="expenseCategory" bindinput="handleEditInput" />
      </view>
      <view class="edit-field edit-field-last">
        <view class="edit-label">备注</view>
        <textarea class="edit-textarea" data-field="remark" bindinput="handleEditInput">{{editForm.remark}}</textarea>
      </view>
      <view class="edit-save-btn" bindtap="saveReimbursement">保存报销信息</view>
    </view>
  </view>

  <view class="section-card">
    <view class="section-head">
      <view class="section-title">关联发票</view>
      <view class="section-link" data-page="/pages/folder/index" bindtap="handleTap">去票夹挑选</view>
    </view>
    <view class="invoice-list">
      <view class="invoice-item" wx:for="{{invoices}}" wx:key="title" wx:for-item="item">
        <view>
          <view class="invoice-title">{{item.title}}</view>
          <view class="invoice-status">{{item.status}}</view>
        </view>
        <view class="invoice-amount">{{item.amount}}</view>
      </view>
    </view>
  </view>

  <view class="section-card">
    <view class="section-title">流程记录</view>
    <view class="timeline">
      <view class="timeline-item" wx:for="{{timeline}}" wx:key="title" wx:for-item="item">
        <view class="timeline-dot"></view>
        <view class="timeline-main">
          <view class="timeline-title">{{item.title}}</view>
          <view class="timeline-meta">{{item.meta}}</view>
        </view>
      </view>
    </view>
  </view>

  <view class="section-card" wx:if="{{reimbursementId && currentView.status === '草稿'}}">
    <view class="section-title">草稿操作</view>
    <view class="section-link section-link-danger" bindtap="deleteDraft">删除当前草稿</view>
  </view>

  <view class="bottom-actions">
    <view class="secondary-btn" data-page="/pages/export-center/index?type=pdf&scope=reimburse" bindtap="handleTap">导出 PDF</view>
    <view class="secondary-btn" data-page="/pages/export-center/index?type=excel&scope=reimburse" bindtap="handleTap">导出 Excel</view>
    <view class="primary-btn" data-label="提交报销单" bindtap="handleTap">{{currentView.status === '已提交' ? '已提交' : '提交报销单'}}</view>
  </view>
</view>
