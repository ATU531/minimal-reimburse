page {
  background: #f4f7fb;
}

.page {
  padding: 24rpx;
  font-family: PingFang SC;
}

.hero-card,
.group-card,
.tips-card {
  padding: 30rpx;
  border-radius: 30rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 30rpx rgba(16, 24, 40, 0.05);
}

.hero-card {
  background: linear-gradient(135deg, #ffffff 0%, #edf2ff 100%);
}

.hero-title {
  font-size: 38rpx;
  font-weight: 600;
  color: #101828;
}

.hero-desc {
  margin-top: 14rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #667085;
}

.group-card,
.tips-card {
  margin-top: 22rpx;
}

.group-title,
.tips-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #101828;
}

.setting-item {
  display: flex;
  justify-content: space-between;
  gap: 18rpx;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f2f4f7;
}

.setting-item:last-child {
  border-bottom: none;
}

.setting-label {
  flex: 1;
  font-size: 24rpx;
  color: #101828;
}

.setting-state {
  flex-shrink: 0;
  font-size: 22rpx;
  color: #4f6ef7;
}

.tips-text {
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #667085;
}
