page {
  background: #f4f7fb;
}

.page {
  padding: 24rpx;
  font-family: PingFang SC;
}

.profile-card {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 32rpx;
  border-radius: 30rpx;
  background: linear-gradient(135deg, #ffffff 0%, #edf2ff 100%);
  box-shadow: 0 10rpx 30rpx rgba(16, 24, 40, 0.05);
}

.avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 32rpx;
  background: linear-gradient(135deg, #4f6ef7 0%, #7c96ff 100%);
  color: #ffffff;
  font-size: 36rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}

.profile-main {
  flex: 1;
}

.profile-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #101828;
}

.profile-subtitle {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #667085;
}

.invite-card {
  margin-top: 22rpx;
  padding: 28rpx;
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 30rpx rgba(16, 24, 40, 0.05);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.invite-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #101828;
}

.invite-desc {
  margin-top: 12rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #667085;
}

.invite-link {
  color: #4f6ef7;
  font-size: 24rpx;
}

.stats-row {
  display: flex;
  gap: 16rpx;
  margin-top: 22rpx;
}

.stat-card {
  flex: 1;
  padding: 22rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 30rpx rgba(16, 24, 40, 0.05);
}

.stat-value {
  font-size: 32rpx;
  font-weight: 600;
  color: #101828;
}

.stat-label {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #667085;
}

.group-card {
  margin-top: 22rpx;
  padding: 10rpx 24rpx;
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 30rpx rgba(16, 24, 40, 0.05);
}

.group-title {
  padding: 20rpx 0 12rpx;
  font-size: 24rpx;
  color: #667085;
}

.menu-item {
  height: 92rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-top: 1rpx solid #f2f4f7;
}

.menu-label {
  font-size: 28rpx;
  color: #101828;
}

.menu-arrow {
  color: #98a2b3;
  font-size: 32rpx;
}
