<view class="page">
  <view class="hero-card">
    <view class="hero-kicker">录入详情</view>
    <view class="hero-title">{{currentSource.title}}</view>
    <view class="hero-desc">{{currentSource.subtitle}}</view>
    <view class="hero-guide">{{currentSource.guide}}</view>
  </view>

  <block wx:if="{{isOcrMode}}">
    <view class="section-card">
      <view class="section-title">拍照/选择图片</view>
      <block wx:if="{{!ocrImage}}">
        <view class="ocr-actions">
          <view class="ocr-btn primary" bindtap="takePhoto">
            <view class="ocr-btn-icon">📷</view>
            <view class="ocr-btn-text">拍照识别</view>
          </view>
          <view class="ocr-btn secondary" bindtap="chooseFromAlbum">
            <view class="ocr-btn-icon">🖼️</view>
            <view class="ocr-btn-text">相册选择</view>
          </view>
        </view>
      </block>
      <block wx:else>
        <view class="image-preview-container">
          <image
            class="preview-image"
            src="{{ocrImage}}"
            mode="aspectFit"
          ></image>
          <view class="image-overlay">
            <block wx:if="{{ocrLoading}}">
              <view class="loading-mask">
                <view class="loading-spinner"></view>
                <view class="loading-text">正在识别...</view>
              </view>
            </block>
            <block wx:elif="{{ocrResult}}">
              <view class="success-badge">
                <view class="success-icon">✓</view>
                <view class="success-text">识别成功</view>
              </view>
            </block>
            <view class="remove-image-btn" bindtap="removeOcrImage">✕ 重新拍摄</view>
          </view>
        </view>
      </block>
    </view>

    <block wx:if="{{ocrResult}}">
      <view class="section-card ocr-result-card">
        <view class="section-title">识别结果预览</view>
        <block wx:if="{{ocrProvider === 'mock'}}">
          <view class="mock-mode-notice">
            <view class="mock-icon">⚠️</view>
            <view class="mock-text">
              <view class="mock-title">模拟模式（开发测试）</view>
              <view class="mock-desc">当前显示的是预设测试数据，非真实OCR识别结果</view>
            </view>
          </view>
        </block>
        <view class="confidence-bar">
          <view class="confidence-label">识别置信度</view>
          <view class="confidence-value">{{ocrResult.confidence || 0}}%</view>
        </view>
        <view class="result-grid">
          <view class="result-item {{ocrResult.title ? 'filled' : ''}}" wx:if="{{ocrResult.title}}">
            <view class="result-label">发票标题</view>
            <view class="result-value">{{ocrResult.title}}</view>
          </view>
          <view class="result-item {{ocrResult.totalAmount || ocrResult.amount ? 'filled' : ''}}" wx:if="{{ocrResult.totalAmount || ocrResult.amount}}">
            <view class="result-label">金额（元）</view>
            <view class="result-value highlight">{{(ocrResult.totalAmount || ocrResult.amount) / 100}}</view>
          </view>
          <view class="result-item {{ocrResult.issueDate ? 'filled' : ''}}" wx:if="{{ocrResult.issueDate}}">
            <view class="result-label">开票日期</view>
            <view class="result-value">{{ocrResult.issueDate}}</view>
          </view>
          <view class="result-item {{ocrResult.buyerName ? 'filled' : ''}}" wx:if="{{ocrResult.buyerName}}">
            <view class="result-label">购买方</view>
            <view class="result-value">{{ocrResult.buyerName}}</view>
          </view>
          <view class="result-item {{ocrResult.sellerName ? 'filled' : ''}}" wx:if="{{ocrResult.sellerName}}">
            <view class="result-label">销售方</view>
            <view class="result-value">{{ocrResult.sellerName}}</view>
          </view>
          <view class="result-item {{ocrResult.invoiceCode ? 'filled' : ''}}" wx:if="{{ocrResult.invoiceCode}}">
            <view class="result-label">发票代码</view>
            <view class="result-value">{{ocrResult.invoiceCode}}</view>
          </view>
          <view class="result-item {{ocrResult.invoiceNumber ? 'filled' : ''}}" wx:if="{{ocrResult.invoiceNumber}}">
            <view class="result-label">发票号码</view>
            <view class="result-value">{{ocrResult.invoiceNumber}}</view>
          </view>
        </view>
      </view>
    </block>

    <view class="section-card">
      <view class="section-title">补充/修改信息</view>
      <view class="form-group">
        <view class="form-label">发票标题 <text class="required">*</text></view>
        <input
          class="form-input {{errors.title ? 'error' : ''}}"
          placeholder="请输入发票标题"
          value="{{form.title}}"
          data-field="title"
          bindinput="handleInput"
        />
        <view class="error-text" wx:if="{{errors.title}}">{{errors.title}}</view>
      </view>

      <view class="form-group">
        <view class="form-label">发票金额（元）<text class="required">*</text></view>
        <input
          class="form-input {{errors.amount ? 'error' : ''}}"
          type="digit"
          placeholder="请输入金额"
          value="{{form.amount}}"
          data-field="amount"
          bindinput="handleInput"
        />
        <view class="error-text" wx:if="{{errors.amount}}">{{errors.amount}}</view>
      </view>

      <view class="form-group">
        <view class="form-label">开票日期 <text class="required">*</text></view>
        <picker
          mode="date"
          value="{{form.issueDate}}"
          data-field="issueDate"
          bindchange="handleDateChange"
        >
          <view class="form-input picker-value {{errors.issueDate ? 'error' : ''}}">
            {{form.issueDate || '请选择日期'}}
          </view>
        </picker>
        <view class="error-text" wx:if="{{errors.issueDate}}">{{errors.issueDate}}</view>
      </view>

      <view class="form-group">
        <view class="form-label">发票类型</view>
        <picker
          mode="selector"
          range="{{invoiceTypeOptions}}"
          range-key="label"
          value="{{invoiceTypeIndex}}"
          bindchange="handleInvoiceTypeChange"
        >
          <view class="form-input picker-value">
            {{invoiceTypeOptions[invoiceTypeIndex].label}}
          </view>
        </picker>
      </view>

      <view class="form-row">
        <view class="form-group flex-1">
          <view class="form-label">购买方名称</view>
          <input
            class="form-input"
            placeholder="选填"
            value="{{form.buyerName}}"
            data-field="buyerName"
            bindinput="handleInput"
          />
        </view>
        <view class="form-group flex-1">
          <view class="form-label">销售方名称</view>
          <input
            class="form-input"
            placeholder="选填"
            value="{{form.sellerName}}"
            data-field="sellerName"
            bindinput="handleInput"
          />
        </view>
      </view>

      <view class="form-row">
        <view class="form-group flex-1">
          <view class="form-label">发票代码</view>
          <input
            class="form-input"
            placeholder="选填"
            value="{{form.invoiceCode}}"
            data-field="invoiceCode"
            bindinput="handleInput"
          />
        </view>
        <view class="form-group flex-1">
          <view class="form-label">发票号码</view>
          <input
            class="form-input"
            placeholder="选填"
            value="{{form.invoiceNumber}}"
            data-field="invoiceNumber"
            bindinput="handleInput"
          />
        </view>
      </view>

      <view class="form-group">
        <view class="form-label">费用类别</view>
        <input
          class="form-input"
          placeholder="选填，如：餐饮、交通、住宿等"
          value="{{form.category}}"
          data-field="category"
          bindinput="handleInput"
        />
      </view>

      <view class="form-group">
        <view class="form-label">备注信息</view>
        <textarea
          class="form-textarea"
          placeholder="选填"
          value="{{form.remark}}"
          data-field="remark"
          bindinput="handleInput"
          maxlength="200"
        ></textarea>
      </view>
    </view>
  </block>

  <block wx:elif="{{isChatMode}}">
    <view class="section-card">
      <view class="section-title">选择文件</view>
      <block wx:if="{{!selectedFile}}">
        <view class="file-upload-area" bindtap="chooseMessageFile">
          <view class="upload-icon">📄</view>
          <view class="upload-text">点击选择聊天中的PDF发票</view>
          <view class="upload-hint">支持 .pdf 格式</view>
        </view>
      </block>
      <block wx:else>
        <view class="selected-file-card">
          <view class="file-info">
            <view class="file-icon">📋</view>
            <view class="file-details">
              <view class="file-name">{{selectedFile.name}}</view>
              <view class="file-meta">{{selectedFile.size}} KB · {{selectedFile.time}}</view>
            </view>
          </view>
          <view class="file-remove" bindtap="removeSelectedFile">✕</view>
        </view>
      </block>
    </view>

    <view class="section-card">
      <view class="section-title">发票信息</view>
      <view class="form-group">
        <view class="form-label">发票标题 <text class="required">*</text></view>
        <input
          class="form-input {{errors.title ? 'error' : ''}}"
          placeholder="请输入发票标题"
          value="{{form.title}}"
          data-field="title"
          bindinput="handleInput"
        />
        <view class="error-text" wx:if="{{errors.title}}">{{errors.title}}</view>
      </view>

      <view class="form-group">
        <view class="form-label">发票金额（元）<text class="required">*</text></view>
        <input
          class="form-input {{errors.amount ? 'error' : ''}}"
          type="digit"
          placeholder="请输入金额"
          value="{{form.amount}}"
          data-field="amount"
          bindinput="handleInput"
        />
        <view class="error-text" wx:if="{{errors.amount}}">{{errors.amount}}</view>
      </view>

      <view class="form-group">
        <view class="form-label">开票日期 <text class="required">*</text></view>
        <picker
          mode="date"
          value="{{form.issueDate}}"
          data-field="issueDate"
          bindchange="handleDateChange"
        >
          <view class="form-input picker-value {{errors.issueDate ? 'error' : ''}}">
            {{form.issueDate || '请选择日期'}}
          </view>
        </picker>
        <view class="error-text" wx:if="{{errors.issueDate}}">{{errors.issueDate}}</view>
      </view>

      <view class="form-group">
        <view class="form-label">发票类型</view>
        <picker
          mode="selector"
          range="{{invoiceTypeOptions}}"
          range-key="label"
          value="{{invoiceTypeIndex}}"
          bindchange="handleInvoiceTypeChange"
        >
          <view class="form-input picker-value">
            {{invoiceTypeOptions[invoiceTypeIndex].label}}
          </view>
        </picker>
      </view>

      <view class="form-row">
        <view class="form-group flex-1">
          <view class="form-label">购买方名称</view>
          <input
            class="form-input"
            placeholder="选填"
            value="{{form.buyerName}}"
            data-field="buyerName"
            bindinput="handleInput"
          />
        </view>
        <view class="form-group flex-1">
          <view class="form-label">销售方名称</view>
          <input
            class="form-input"
            placeholder="选填"
            value="{{form.sellerName}}"
            data-field="sellerName"
            bindinput="handleInput"
          />
        </view>
      </view>

      <view class="form-row">
        <view class="form-group flex-1">
          <view class="form-label">发票代码</view>
          <input
            class="form-input"
            placeholder="选填"
            value="{{form.invoiceCode}}"
            data-field="invoiceCode"
            bindinput="handleInput"
          />
        </view>
        <view class="form-group flex-1">
          <view class="form-label">发票号码</view>
          <input
            class="form-input"
            placeholder="选填"
            value="{{form.invoiceNumber}}"
            data-field="invoiceNumber"
            bindinput="handleInput"
          />
        </view>
      </view>

      <view class="form-group">
        <view class="form-label">费用类别</view>
        <input
          class="form-input"
          placeholder="选填，如：餐饮、交通、住宿等"
          value="{{form.category}}"
          data-field="category"
          bindinput="handleInput"
        />
      </view>

      <view class="form-group">
        <view class="form-label">备注信息</view>
        <textarea
          class="form-textarea"
          placeholder="选填"
          value="{{form.remark}}"
          data-field="remark"
          bindinput="handleInput"
          maxlength="200"
        ></textarea>
      </view>
    </view>
  </block>

  <block wx:else>
    <view class="section-card">
      <view class="section-title">流程结构</view>
      <view class="step-list">
        <view class="step-item" wx:for="{{sections}}" wx:key="title" wx:for-item="item">
          <view class="step-dot"></view>
          <view class="step-content">
            <view class="step-title">{{item.title}}</view>
            <view class="step-detail">{{item.detail}}</view>
          </view>
        </view>
      </view>
    </view>

    <view class="section-card">
      <view class="section-title">识别结果预览</view>
      <view class="preview-grid">
        <view class="preview-item">
          <view class="preview-label">发票金额</view>
          <view class="preview-value">¥3,980.00</view>
        </view>
        <view class="preview-item">
          <view class="preview-label">发票类型</view>
          <view class="preview-value">电子专票</view>
        </view>
        <view class="preview-item">
          <view class="preview-label">购买方</view>
          <view class="preview-value">上海知行科技有限公司</view>
        </view>
        <view class="preview-item">
          <view class="preview-label">开票日期</view>
          <view class="preview-value">2026-03-24</view>
        </view>
      </view>
    </view>

    <view class="section-card">
      <view class="section-title">最近导入</view>
      <view class="recent-list">
        <view class="recent-item" wx:for="{{recentRecords}}" wx:key="title" wx:for-item="item">
          <view class="recent-title">{{item.title}}</view>
          <view class="recent-meta">{{item.meta}}</view>
        </view>
      </view>
    </view>
  </block>

  <view class="bottom-actions">
    <block wx:if="{{isOcrMode}}">
      <view class="secondary-btn" bindtap="takePhoto" wx:if="{{!ocrImage}}">拍照识别</view>
      <view class="primary-btn {{submitting ? 'disabled' : ''}}" bindtap="handleSubmit" wx:else>
        {{submitting ? '保存中...' : (ocrResult ? '保存到票夹' : '请等待识别完成')}}
      </view>
    </block>
    <block wx:elif="{{isChatMode}}">
      <view class="secondary-btn" bindtap="chooseMessageFile" wx:if="{{!selectedFile}}">选择文件</view>
      <view class="primary-btn {{submitting ? 'disabled' : ''}}" bindtap="handleSubmit">
        {{submitting ? '保存中...' : '保存到票夹'}}
      </view>
    </block>
    <block wx:else>
      <view class="secondary-btn" data-label="预览识别" bindtap="handleTap">预览识别</view>
      <view class="primary-btn" data-label="{{currentSource.actionLabel || '保存到票夹'}}" data-page="{{currentSource.actionPage}}" bindtap="handleTap">{{currentSource.actionLabel || '保存到票夹'}}</view>
    </block>
  </view>
</view>
