<view class="page">
  <view class="hero-card">
    <view class="hero-kicker">录入详情</view>
    <view class="hero-title">{{currentSource.title}}</view>
    <view class="hero-desc">{{currentSource.subtitle}}</view>
    <view class="hero-guide">{{currentSource.guide}}</view>
  </view>

  <view class="section-card">
    <view class="section-title">流程结构</view>
    <view class="step-list">
      <view class="step-item" wx:for="{{sections}}" wx:key="title" wx:for-item="item">
        <view class="step-dot"></view>
        <view class="step-content">
          <view class="step-title">{{item.title}}</view>
          <view class="step-detail">{{item.detail}}</view>
        </view>
      </view>
    </view>
  </view>

  <view class="section-card">
    <view class="section-title">识别结果预览</view>
    <view class="preview-grid">
      <view class="preview-item">
        <view class="preview-label">发票金额</view>
        <view class="preview-value">¥3,980.00</view>
      </view>
      <view class="preview-item">
        <view class="preview-label">发票类型</view>
        <view class="preview-value">电子专票</view>
      </view>
      <view class="preview-item">
        <view class="preview-label">购买方</view>
        <view class="preview-value">上海知行科技有限公司</view>
      </view>
      <view class="preview-item">
        <view class="preview-label">开票日期</view>
        <view class="preview-value">2026-03-24</view>
      </view>
    </view>
  </view>

  <view class="section-card">
    <view class="section-title">最近导入</view>
    <view class="recent-list">
      <view class="recent-item" wx:for="{{recentRecords}}" wx:key="title" wx:for-item="item">
        <view class="recent-title">{{item.title}}</view>
        <view class="recent-meta">{{item.meta}}</view>
      </view>
    </view>
  </view>

  <view class="bottom-actions">
    <view class="secondary-btn" data-label="预览识别" bindtap="handleTap">预览识别</view>
    <view class="primary-btn" data-label="保存到票夹" bindtap="handleTap">保存到票夹</view>
  </view>
</view>
