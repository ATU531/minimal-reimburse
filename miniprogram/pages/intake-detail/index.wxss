page {
  background: #f4f7fb;
}

.page {
  padding: 24rpx 24rpx 180rpx;
  font-family: PingFang SC;
}

.hero-card,
.section-card {
  background: #ffffff;
  border-radius: 30rpx;
  padding: 30rpx;
  box-shadow: 0 10rpx 30rpx rgba(16, 24, 40, 0.05);
}

.hero-card {
  background: linear-gradient(135deg, #ffffff 0%, #edf2ff 100%);
}

.hero-kicker {
  font-size: 24rpx;
  color: #4f6ef7;
}

.hero-title {
  margin-top: 14rpx;
  font-size: 40rpx;
  font-weight: 600;
  color: #101828;
}

.hero-desc,
.hero-guide {
  margin-top: 14rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #667085;
}

.section-card {
  margin-top: 22rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #101828;
}

.ocr-actions {
  margin-top: 20rpx;
  display: flex;
  gap: 24rpx;
  justify-content: center;
}

.ocr-btn {
  flex: 1;
  max-width: 300rpx;
  padding: 40rpx 32rpx;
  border-radius: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.ocr-btn.primary {
  background: linear-gradient(135deg, #4f6ef7 0%, #7c96ff 100%);
  box-shadow: 0 14rpx 30rpx rgba(79, 110, 247, 0.2);
}

.ocr-btn.secondary {
  background: #ffffff;
  box-shadow: 0 10rpx 30rpx rgba(16, 24, 40, 0.05);
  border: 2rpx solid #e5e7eb;
}

.ocr-btn-icon {
  font-size: 56rpx;
}

.ocr-btn-text {
  font-size: 26rpx;
  font-weight: 500;
  color: #ffffff;
}

.ocr-btn.secondary .ocr-btn-text {
  color: #344054;
}

.image-preview-container {
  margin-top: 20rpx;
  position: relative;
  border-radius: 24rpx;
  overflow: hidden;
  background: #f8fafc;
}

.preview-image {
  width: 100%;
  height: 500rpx;
  display: block;
}

.image-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0, 0, 0, 0.3);
}

.loading-mask {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  padding: 60rpx;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 24rpx;
}

.loading-spinner {
  width: 64rpx;
  height: 64rpx;
  border: 6rpx solid #e5e7eb;
  border-top-color: #4f6ef7;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.loading-text {
  font-size: 28rpx;
  color: #344054;
  font-weight: 500;
}

.success-badge {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 24rpx 40rpx;
  background: rgba(16, 185, 129, 0.95);
  border-radius: 24rpx;
}

.success-icon {
  width: 48rpx;
  height: 48rpx;
  background: #ffffff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #10b981;
  font-weight: bold;
}

.success-text {
  font-size: 28rpx;
  color: #ffffff;
  font-weight: 500;
}

.remove-image-btn {
  position: absolute;
  bottom: 24rpx;
  left: 50%;
  transform: translateX(-50%);
  padding: 16rpx 36rpx;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 40rpx;
  font-size: 24rpx;
  color: #667085;
  font-weight: 500;
}

.ocr-result-card {
  border-left: 8rpx solid #10b981;
}

.mock-mode-notice {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
  padding: 20rpx 24rpx;
  background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%);
  border-radius: 16rpx;
  border-left: 6rpx solid #f59e0b;
}

.mock-icon {
  font-size: 36rpx;
}

.mock-text {
  flex: 1;
}

.mock-title {
  font-size: 26rpx;
  color: #92400e;
  font-weight: 600;
}

.mock-desc {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #b45309;
}

.confidence-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding: 16rpx 20rpx;
  background: linear-gradient(135deg, #ecfdf5 0%, #d1fae5 100%);
  border-radius: 16rpx;
}

.confidence-label {
  font-size: 24rpx;
  color: #065f46;
  font-weight: 500;
}

.confidence-value {
  font-size: 32rpx;
  color: #059669;
  font-weight: 700;
}

.result-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
  margin-top: 16rpx;
}

.result-item {
  padding: 20rpx;
  border-radius: 16rpx;
  background: #f8fafc;
  border: 2rpx solid transparent;
  transition: all 0.3s ease;
}

.result-item.filled {
  background: #f0fdf4;
  border-color: #86efac;
}

.result-label {
  font-size: 22rpx;
  color: #667085;
  margin-bottom: 8rpx;
}

.result-value {
  font-size: 26rpx;
  color: #101828;
  font-weight: 500;
  word-break: break-all;
}

.result-value.highlight {
  color: #059669;
  font-size: 30rpx;
  font-weight: 700;
}

.file-upload-area {
  margin-top: 20rpx;
  padding: 60rpx 40rpx;
  border-radius: 24rpx;
  border: 2rpx dashed #d0d5dd;
  background: #f8fafc;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.chat-select-grid {
  margin-top: 20rpx;
  display: flex;
  gap: 20rpx;
}

.chat-select-card {
  flex: 1;
  padding: 36rpx 24rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #f8fafc 0%, #f1f5f9 100%);
  border: 2rpx solid #e2e8f0;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  transition: all 0.2s ease;
}

.chat-select-card:active {
  transform: scale(0.97);
  border-color: #4f6ef7;
  background: linear-gradient(135deg, #eff6ff 0%, #dbeafe 100%);
}

.chat-select-icon {
  font-size: 56rpx;
}

.chat-select-text {
  font-size: 28rpx;
  color: #101828;
  font-weight: 600;
}

.chat-select-hint {
  font-size: 22rpx;
  color: #667085;
  text-align: center;
}

.chat-tips {
  margin-top: 24rpx;
  padding: 20rpx 24rpx;
  background: #fffbeb;
  border-radius: 16rpx;
  border-left: 6rpx solid #f59e0b;
  display: flex;
  gap: 16rpx;
}

.tips-icon {
  font-size: 32rpx;
  flex-shrink: 0;
}

.tips-content {
  flex: 1;
}

.tips-title {
  font-size: 24rpx;
  color: #92400e;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.tips-item {
  font-size: 22rpx;
  color: #b45309;
  line-height: 1.6;
}

.upload-icon {
  font-size: 64rpx;
}

.upload-text {
  font-size: 28rpx;
  color: #344054;
  font-weight: 500;
}

.upload-hint {
  font-size: 22rpx;
  color: #98a2b3;
}

.selected-file-card {
  margin-top: 20rpx;
  padding: 24rpx 28rpx;
  border-radius: 24rpx;
  background: #f8fafc;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.file-info {
  display: flex;
  align-items: center;
  gap: 20rpx;
  flex: 1;
}

.file-icon {
  font-size: 48rpx;
}

.file-details {
  flex: 1;
}

.file-name {
  font-size: 28rpx;
  color: #101828;
  font-weight: 500;
  word-break: break-all;
}

.file-meta {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #667085;
}

.file-remove {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #fee2e2;
  color: #dc2626;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  margin-left: 16rpx;
}

.form-group {
  margin-top: 24rpx;
}

.form-row {
  display: flex;
  gap: 20rpx;
  margin-top: 24rpx;
}

.flex-1 {
  flex: 1;
}

.form-label {
  font-size: 26rpx;
  color: #344054;
  font-weight: 500;
  margin-bottom: 12rpx;
}

.required {
  color: #dc2626;
  margin-left: 4rpx;
}

.form-input {
  height: 84rpx;
  padding: 0 24rpx;
  border-radius: 16rpx;
  background: #f8fafc;
  border: 2rpx solid #e5e7eb;
  font-size: 28rpx;
  color: #101828;
  box-sizing: border-box;
}

.form-input.error {
  border-color: #dc2626;
  background: #fef2f2;
}

.picker-value {
  line-height: 80rpx;
  color: #667085;
}

.form-textarea {
  width: 100%;
  min-height: 140rpx;
  padding: 20rpx 24rpx;
  border-radius: 16rpx;
  background: #f8fafc;
  border: 2rpx solid #e5e7eb;
  font-size: 28rpx;
  color: #101828;
  box-sizing: border-box;
}

.error-text {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #dc2626;
}

.step-list {
  margin-top: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.step-item {
  display: flex;
  gap: 16rpx;
}

.step-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  margin-top: 12rpx;
  background: linear-gradient(135deg, #4f6ef7 0%, #7c96ff 100%);
}

.step-content {
  flex: 1;
}

.step-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #101828;
}

.step-detail {
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.7;
  color: #667085;
}

.preview-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 20rpx;
}

.preview-item {
  width: calc(50% - 8rpx);
  padding: 24rpx;
  box-sizing: border-box;
  border-radius: 24rpx;
  background: #f8faff;
}

.preview-label {
  font-size: 22rpx;
  color: #667085;
}

.preview-value {
  margin-top: 12rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #101828;
  line-height: 1.5;
}

.recent-list {
  margin-top: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.recent-item {
  padding: 22rpx 24rpx;
  border-radius: 22rpx;
  background: #f8fafc;
}

.recent-title {
  font-size: 26rpx;
  color: #101828;
}

.recent-meta {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #667085;
}

.bottom-actions {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: calc(env(safe-area-inset-bottom) + 20rpx);
  display: flex;
  gap: 16rpx;
}

.secondary-btn,
.primary-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
}

.secondary-btn {
  background: #ffffff;
  color: #344054;
  box-shadow: 0 10rpx 30rpx rgba(16, 24, 40, 0.05);
}

.primary-btn {
  background: linear-gradient(135deg, #4f6ef7 0%, #7c96ff 100%);
  color: #ffffff;
  box-shadow: 0 14rpx 30rpx rgba(79, 110, 247, 0.2);
}

.primary-btn.disabled {
  opacity: 0.6;
}

.chat-ocr-loading {
  margin-top: 20rpx;
  padding: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  background: #f8fafc;
  border-radius: 16rpx;
}

.chat-image-preview {
  margin-top: 20rpx;
  border-radius: 24rpx;
  overflow: hidden;
  background: #f8fafc;
}
